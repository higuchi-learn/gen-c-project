// --- ユーザ ---
Table users {
  id integer [primary key]
  username varchar [note: 'ログインID']
  display_name varchar [note: '表示名']
  email varchar [unique]
  password varchar
  icon_image varchar [note: 'アイコン画像URL']
  residence varchar [note: '居住地']
  created_at timestamp

  note: 'アカウント情報・編集画面の項目'
}

// --- スポット ---
Table spots {
  id integer [primary key, increment]
  user_id integer [ref: > users.id, note: '投稿者ID（ゲスト投稿ならNULL）']
  name varchar [note: 'スポットの名前']
  description text [note: '説明']
  lat decimal [note: '緯度']
  lng decimal [note: '経度']
  image_url varchar [note: '写真URL']
  created_at timestamp
  updated_at timestamp

  note: 'マップ上に立てるピンと情報管理'
}

// --- アクション ---

Table spot_visits {
  id integer [primary key]
  user_id integer [ref: > users.id]
  spot_id integer [ref: > spots.id]
  created_at timestamp

  note: '発見した数の管理'
}

Table likes {
  user_id integer [ref: > users.id, note: 'いいね数不正対策']
  spot_id integer [ref: > spots.id]
  created_at timestamp

  indexes {
    (user_id, spot_id) [pk]
  }
  note: 'いいね管理'
}

Table comments {
  id integer [primary key]
  user_id integer [ref: > users.id]
  spot_id integer [ref: > spots.id]
  content text
  created_at timestamp

  note: 'コメント管理'
}
